# Shared password gate (FR-001). Never commit the real value.
APP_PASSWORD=change-me

# AWS Amplify Hosting (Gen 2) runtime. lib/aws.ts uses the attached SSR compute
# role (aicoe-amplify-ssr-role) via the default credential chain — no keys here.
# On Amplify, set these as branch env vars; locally they are only needed if you
# exercise the Lambda invoke path.
AWS_REGION=us-east-1
AICOE_ORCHESTRATOR_FN=aicoe-fargate-orchestrator-endpoint-lambda
